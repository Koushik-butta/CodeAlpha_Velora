# Velora — copy to .env and fill in values.
#
# Setup:
#   python -m venv venv && venv\Scripts\activate   (Windows)
#   pip install -r requirements.txt
#   copy .env.example .env                         (then edit .env)
#   python manage.py migrate
#   python manage.py runserver
#
# Phase 0 uses PostgreSQL in production. For local dev without Postgres:
# USE_SQLITE_DEV=True
# If you previously used db.sqlite3 with the default User model, delete db.sqlite3 before migrating.

SECRET_KEY=change-me-to-a-long-random-string
USE_SQLITE_DEV=False
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (preferred: single URL)
DATABASE_URL=postgresql://velora_user:velora_pass@localhost:5432/velora_db

# Or discrete PG vars (used if DATABASE_URL is unset)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=velora_db
# PGUSER=velora_user
# PGPASSWORD=velora_pass

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=Velora

OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
